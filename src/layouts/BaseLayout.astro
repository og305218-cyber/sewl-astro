---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SEWL — Spiritually Evolving With Love',
  description = 'A sacred space for women choosing alignment, discipline, and divine living.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body transition:animate="fade">
    <slot />
    <script type="module">import '../scripts/main.ts';</script>
    <script type="module">
      import { navigate } from 'astro:transitions/client';

      void navigate;

      const dispatchReady = () => {
        window.dispatchEvent(new Event('sewl:page-ready'));
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', dispatchReady, { once: true });
      } else {
        dispatchReady();
      }

      document.addEventListener('astro:page-load', () => {
        window.dispatchEvent(new Event('sewl:page-ready'));
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.9;
    background: #1A0A2E;
    color: #FAF6F0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  h1, h2, h3, h4 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.05;
  }

  ::selection {
    background: rgba(196,149,106,0.3);
    color: #1A0A2E;
  }

  em, i {
    font-style: italic;
    letter-spacing: 0.04em;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  a:hover { opacity: 0.82; }

  [data-scroll-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.9s ease, transform 0.9s ease;
  }

  [data-scroll-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
