---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SEWL — Spiritually Evolving With Love',
  description = 'A sacred space for women choosing alignment, discipline, and divine living.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body transition:animate="fade">
    <slot />
    <script type="module">import '../scripts/main.ts';</script>
  </body>
</html>

<style is:global>
  :root {
    --sewl-primary: #1a0a2e;
    --sewl-accent: #c4956a;
    --sewl-surface: #faf6f0;
    --sewl-accent-secondary: #8b5e3c;
    --sewl-heading: 'Cormorant Garamond', serif;
    --sewl-body: 'DM Sans', sans-serif;
    --sewl-width: min(1240px, calc(100vw - 40px));
    --sewl-padding: clamp(20px, 4vw, 40px);
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.9;
    background: #1a0a2e;
    color: #faf6f0;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  h1, h2, h3, h4 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  a:hover {
    opacity: 0.82;
  }

  button,
  input,
  textarea {
    font: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  ::selection {
    background: rgba(196, 149, 106, 0.3);
    color: #1a0a2e;
  }

  em, i {
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(circle at 18% 14%, rgba(196, 149, 106, 0.18), transparent 24%),
      radial-gradient(circle at 82% 10%, rgba(250, 246, 240, 0.08), transparent 18%),
      linear-gradient(180deg, rgba(18, 7, 31, 1) 0%, rgba(26, 10, 46, 1) 52%, rgba(18, 7, 30, 1) 100%);
  }

  .page-shell--default {
    background:
      radial-gradient(circle at 14% 12%, rgba(196, 149, 106, 0.18), transparent 22%),
      linear-gradient(180deg, rgba(18, 7, 30, 1) 0%, rgba(26, 10, 46, 1) 52%, rgba(17, 6, 28, 1) 100%);
  }

  .page-shell--alt {
    background:
      radial-gradient(circle at 20% 16%, rgba(196, 149, 106, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(20, 8, 34, 1) 0%, rgba(26, 10, 46, 1) 52%, rgba(18, 7, 29, 1) 100%);
  }

  .container {
    width: var(--sewl-width);
    margin: 0 auto;
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: clamp(132px, 18vw, 192px) 0 clamp(88px, 12vw, 132px);
  }

  .hero--inner {
    min-height: auto;
    padding-bottom: 86px;
  }

  .hero__content {
    max-width: 900px;
  }

  .hero h1,
  .copy-shell h1,
  .page-shell h2,
  .page-shell h3 {
    text-wrap: balance;
  }

  .hero h1 {
    font-size: clamp(3.9rem, 10vw, 8.2rem);
    max-width: 900px;
  }

  .copy-shell {
    max-width: 860px;
  }

  .copy-shell--narrow {
    max-width: 760px;
  }

  .section {
    padding: clamp(86px, 11vw, 124px) 0;
  }

  .section--tight {
    padding-bottom: clamp(96px, 12vw, 140px);
  }

  .section--light {
    background:
      radial-gradient(ellipse at 30% 50%, rgba(196, 149, 106, 0.06) 0%, transparent 60%),
      #faf6f0;
    color: #1a0a2e;
  }

  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(196, 149, 106, 0.74);
    margin-bottom: 18px;
    padding-left: 0.28em;
  }

  .section-label--light {
    color: rgba(250, 246, 240, 0.72);
  }

  .lead {
    margin-top: 22px;
    max-width: 720px;
    font-size: 1.04rem;
    color: rgba(250, 246, 240, 0.78);
  }

  .lead--serif {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.05rem, 2.1vw, 1.24rem);
    font-style: italic;
    letter-spacing: 0.04em;
    color: rgba(250, 246, 240, 0.8);
  }

  .hero-lines {
    margin-top: 26px;
    font-size: clamp(1.08rem, 2.3vw, 1.34rem);
    color: rgba(250, 246, 240, 0.84);
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .hero-lines span {
    display: block;
  }

  .stack-lg {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .stack-xl {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .light-text {
    color: rgba(26, 10, 46, 0.8);
  }

  .muted-text {
    color: rgba(250, 246, 240, 0.82);
  }

  .muted-text-light {
    color: rgba(26, 10, 46, 0.78);
  }

  .italic-note {
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 14px 26px;
    border: 1px solid #c4956a;
    background: #c4956a;
    color: #1a0a2e;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-radius: 4px;
    padding-left: 0.2em;
  }

  .button--ghost {
    background: transparent;
    color: #faf6f0;
    border-color: rgba(250, 246, 240, 0.22);
  }

  .button--ghost-dark {
    background: transparent;
    color: #1a0a2e;
    border-color: rgba(26, 10, 46, 0.18);
  }

  .scroll-indicator {
    position: absolute;
    right: max(20px, 4vw);
    bottom: 36px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: rgba(250, 246, 240, 0.62);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .scroll-indicator::before {
    content: '';
    width: 1px;
    height: 52px;
    background: linear-gradient(180deg, rgba(196, 149, 106, 0), rgba(196, 149, 106, 0.8));
  }

  .belief-grid,
  .card-grid {
    display: grid;
    gap: 18px;
  }

  .belief-grid {
    margin-top: 18px;
  }

  .card-grid--three {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .card-grid--wide {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .card {
    padding: 30px;
    border-radius: 20px;
    border: 1px solid rgba(196, 149, 106, 0.22);
  }

  .card--plum {
    background: linear-gradient(160deg, rgba(26, 10, 46, 0.97) 0%, rgba(36, 16, 58, 0.95) 100%);
  }

  .card--light {
    background: rgba(255, 255, 255, 0.72);
  }

  .card--soft {
    background: rgba(255, 255, 255, 0.6);
    border-radius: 16px;
  }

  .card h2,
  .card h3 {
    margin-bottom: 14px;
  }

  .card__eyebrow {
    margin-bottom: 18px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c4956a;
    padding-left: 0.3em;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 42px;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid rgba(196, 149, 106, 0.24);
    background: rgba(250, 246, 240, 0.06);
    color: #c4956a;
    font-size: 0.64rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    padding-left: 0.26em;
  }

  .quote-grid {
    display: grid;
    gap: 16px;
    margin-top: 26px;
  }

  .quote-card {
    padding: 22px 24px;
    border-radius: 12px;
    border: 1px solid rgba(196, 149, 106, 0.22);
    background: rgba(250, 246, 240, 0.05);
  }

  .quote-card p {
    font-style: italic;
    letter-spacing: 0.04em;
    color: rgba(250, 246, 240, 0.84);
  }

  .story-grid,
  .membership-grid {
    display: grid;
    gap: 22px;
  }

  .story-grid {
    gap: 24px;
  }

  .shift-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 18px;
    margin-top: 30px;
  }

  .shift-card {
    padding: 26px;
    border: 1px solid rgba(196, 149, 106, 0.22);
    background: rgba(255, 255, 255, 0.72);
    border-radius: 16px;
  }

  .shift-card__before {
    color: rgba(26, 10, 46, 0.62);
  }

  .shift-card__after {
    margin-top: 10px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .pillar-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(320px, 1.05fr);
    gap: clamp(28px, 5vw, 60px);
    align-items: start;
  }

  .contact-grid {
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.86fr);
    gap: clamp(28px, 5vw, 56px);
  }

  .ornament-panel {
    position: relative;
    min-height: 480px;
    border: 1px solid rgba(196, 149, 106, 0.24);
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(250, 246, 240, 0.08) 0%, rgba(196, 149, 106, 0.22) 36%, rgba(26, 10, 46, 0.9) 100%);
    overflow: hidden;
  }

  .ornament-panel__frame {
    position: absolute;
    inset: 10%;
    border: 1px solid rgba(250, 246, 240, 0.3);
    border-radius: 12px;
  }

  .ornament-panel__glow {
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 14%;
    height: 38%;
    border-radius: 999px 999px 0 0;
    background: rgba(250, 246, 240, 0.16);
    filter: blur(28px);
  }

  .form-card {
    display: grid;
    gap: 16px;
  }

  .field {
    width: 100%;
    border: 1px solid rgba(196, 149, 106, 0.24);
    background: rgba(255, 255, 255, 0.76);
    color: #1a0a2e;
    font-size: 1rem;
    line-height: 1.9;
    padding: 16px 18px;
    outline: none;
    border-radius: 6px;
  }

  .field-label {
    display: grid;
    gap: 8px;
  }

  .field-label span {
    font-size: 0.64rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #c4956a;
    padding-left: 0.24em;
  }

  @keyframes fade-out {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-12px); }
  }

  @keyframes sewl-fade-in {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  ::view-transition-old(root) {
    animation: 600ms cubic-bezier(0.76, 0, 0.24, 1) both fade-out;
  }

  ::view-transition-new(root) {
    animation: 600ms cubic-bezier(0.76, 0, 0.24, 1) both sewl-fade-in;
  }

  @media (max-width: 900px) {
    .pillar-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .scroll-indicator {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .button,
    .button--ghost,
    .button--ghost-dark {
      width: 100%;
    }
  }
</style>
