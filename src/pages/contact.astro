---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { tokens } from '../config/tokens';
---

<BaseLayout title="SEWL — Contact" description="Reach out gently and be received with care.">
  <Navbar />

  <main>
    <section class="hero" style={`background: ${tokens.gradientHero}; min-height: 80vh; display: flex; align-items: center; padding: clamp(140px, 18vw, 200px) 0 clamp(80px, 10vw, 120px);`}>
      <div class="container">
        <div class="hero-copy">
          <p class="section-label section-label--light">Contact</p>
          <h1 class="hero-title">Reach Out Gently</h1>
          <p class="hero-subtext">You will be received with care.</p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="contact-section" data-scroll-reveal>
      <div class="container contact-grid">
        <div>
          <p class="section-label">Write</p>
          <form class="form-card">
            <label class="field-label">
              <span>Name</span>
              <input type="text" name="name" />
            </label>
            <label class="field-label">
              <span>Email</span>
              <input type="email" name="email" />
            </label>
            <label class="field-label">
              <span>Message</span>
              <textarea name="message" rows="8"></textarea>
            </label>
            <button class="primary-button" type="submit">Send with Love</button>
          </form>
        </div>

        <div class="side-stack">
          <article class="voice-card" data-scroll-reveal>
            <h2 class="side-title">Prefer to speak?</h2>
            <p class="body-copy">You are welcome to share your heart in your own voice.</p>

            <label class="field-label" style="margin-top: 18px;">
              <span>Upload a voice note</span>
              <input type="file" accept=".mp3,.m4a,.wav" />
            </label>

            <p class="body-copy italic-note" style="margin-top: 14px;">
              Your message will be listened to with full presence.
            </p>
          </article>

          <p class="body-copy italic-note" data-scroll-reveal>
            However you reach out... you will be met with gentleness.
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: min(1240px, calc(100vw - 40px));
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 760px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #c4956a;
  }

  .section-label::before {
    content: '';
    width: 48px;
    height: 1px;
    background: rgba(196,149,106,0.72);
    flex: 0 0 48px;
  }

  .hero-title {
    font-size: clamp(4rem, 11vw, 8.6rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: #faf6f0;
  }

  .hero-subtext {
    margin-top: 20px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.08rem, 2.2vw, 1.28rem);
    line-height: 1.9;
    color: rgba(250,246,240,0.8);
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .contact-section {
    padding: clamp(90px, 12vw, 132px) 0 clamp(60px, 8vw, 96px);
    background: #1a0a2e;
    color: #faf6f0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.86fr);
    gap: clamp(28px, 5vw, 56px);
    align-items: start;
  }

  .form-card,
  .side-stack {
    display: grid;
    gap: 16px;
  }

  .field-label {
    display: grid;
    gap: 8px;
  }

  .field-label span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.64rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #c4956a;
  }

  input, textarea {
    background: rgba(250,246,240,0.06);
    border: 1px solid rgba(196,149,106,0.2);
    border-radius: 8px;
    color: #FAF6F0;
    font-family: 'DM Sans', sans-serif;
    padding: 14px 18px;
    width: 100%;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.3s ease;
  }

  input:focus, textarea:focus {
    border-color: rgba(196,149,106,0.6);
  }

  textarea {
    min-height: 160px;
    resize: vertical;
  }

  .primary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 54px;
    padding: 14px 32px;
    border-radius: 4px;
    background: #c4956a;
    border: 1px solid #c4956a;
    color: #1a0a2e;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .voice-card {
    padding: 30px;
    border: 1px solid rgba(196,149,106,0.2);
    border-radius: 20px;
    background: rgba(250,246,240,0.03);
  }

  .side-title {
    font-size: clamp(2rem, 4.4vw, 3rem);
    line-height: 1.02;
    margin-bottom: 12px;
    color: #faf6f0;
  }

  .body-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.95;
    color: rgba(250,246,240,0.8);
  }

  .italic-note {
    font-style: italic;
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
