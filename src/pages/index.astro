---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { tokens } from '../config/tokens';
import { homeContent, site } from '../data/content';

const headline = 'Return to the way you were meant to live.';
---

<BaseLayout>
  <Navbar />

  <main>
    <section
      class="hero"
      style={`min-height: 100vh; display: flex; align-items: center; padding: clamp(120px, 18vw, 200px) 0 clamp(80px, 12vw, 120px); background: ${tokens.gradientHero}; position: relative; overflow: hidden;`}
    >
      <div class="container">
        <div class="hero-content">
          <p class="section-label section-label--light">{site.operator}</p>
          <h1 class="hero-title">
            {headline.split(' ').map((word) => (
              <span class="hero-word-shell">
                <span class="hero-word">{word}</span>
              </span>
            ))}
          </h1>

          <div class="hero-lines">
            {homeContent.heroSubtextLines.map((line) => (
              <span>{line}</span>
            ))}
          </div>

          <p class="hero-descriptor">
            {`${site.name} is a sacred space for women choosing alignment, discipline, and divine living — one gentle step at a time.`}
          </p>

          <div class="hero-actions">
            <a class="primary-button" href={site.liveUrl}>{`Enter ${site.name}`}</a>
            <a class="ghost-button" href="/the-path">Begin Your Rhythm</a>
          </div>
        </div>
      </div>

      <div class="scroll-indicator">Scroll</div>
    </section>

    <SectionDivider />

    <section class="light-section" data-scroll-reveal style={`background: ${tokens.gradientLight};`}>
      <div class="container two-column">
        <div class="poetic-column">
          <p class="section-label">{`What is ${site.name}`}</p>
          <h2 class="section-heading section-heading--dark">
            This is not a trend.
            <br />
            This is not a phase.
            <br />
            <br />
            This is a return.
          </h2>
          <div class="poetic-copy">
            <p class="body-copy body-copy--dark">
            A return to how we nourish our bodies...
            <br />
            how we care for our homes...
            <br />
            how we speak to ourselves...
            <br />
            and how we live under divine order.
            </p>
            <p class="body-copy body-copy--dark italic-note">{`${site.name} — ${site.fullName} — is a way of living rooted in truth.`}</p>
            <p class="body-copy body-copy--dark">Here, we believe:</p>
            <p class="body-copy body-copy--dark">This is not about doing more.</p>
            <p class="body-copy body-copy--dark">This is about living differently.</p>
          </div>
        </div>

        <div class="belief-column">
          {homeContent.beliefs.map((belief) => (
            <div class="belief-item" data-scroll-reveal>
              <span class="belief-dot"></span>
              <p>{belief}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="dark-section" data-scroll-reveal>
      <div class="container">
        <div class="section-header">
          <p class="section-label section-label--light">The 3 Pillars</p>
          <h2 class="section-heading">Three living rooms for the woman returning to herself.</h2>
        </div>

        <div class="pillars-row">
          {homeContent.pillarCards.map((pillar) => (
            <article class="pillar-card" data-scroll-reveal>
              <div class="card-eyebrow">{pillar.eyebrow}</div>
              <h3 class="card-title">{pillar.title}</h3>
              <p class="body-copy">{pillar.description}</p>
              <div class="card-actions">
                <a class="ghost-button" href={pillar.href}>Explore</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="light-section" data-scroll-reveal style={`background: ${tokens.gradientLight};`}>
      <div class="container shift-shell">
        <div class="section-header section-header--narrow">
          <p class="section-label">What Begins to Shift</p>
          <h2 class="section-heading section-heading--dark">When you move through SEWL, something soft begins to change.</h2>
        </div>

        <div class="shift-copy">
          <p class="body-copy body-copy--dark">
            You feel more grounded in your body.
            <br />
            More clear in your mind.
            <br />
            More present in your home.
          </p>
          <p class="body-copy body-copy--dark">
            You begin to trust your rhythm again.
            <br />
            You begin to care for yourself differently.
          </p>
          <p class="body-copy body-copy--dark">
            Not perfectly...
            <br />
            but intentionally.
          </p>
        </div>

        <div class="shift-pairs">
          {homeContent.shifts.map((shift) => (
            <article class="shift-pair" data-scroll-reveal>
              <span>{shift.before}</span>
              <span class="shift-arrow">→</span>
              <span>{shift.after}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="membership-section" data-scroll-reveal>
      <div class="container membership-shell">
        <div class="section-header section-header--narrow">
          <div>
            <p class="section-label section-label--light">Membership Invitation</p>
            <h2 class="section-heading">
              {`${site.name} is not something you rush through.`}
              <br />
              It is something you return to... daily.
            </h2>
          </div>
        </div>

        <div class="membership-buttons">
          <a class="membership-button" href={site.liveUrl}>{`Enter ${site.name}`}</a>
          <a class="membership-button" href="/the-path">Begin Your Rhythm</a>
          <a class="membership-button" href="/the-path">{`Enter the ${site.circleLabel}`}</a>
        </div>

        <div class="membership-copy">
          <p class="body-copy">No pressure.</p>
          <p class="body-copy">No urgency.</p>
          <p class="body-copy">Just a place to come back to yourself.</p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="closing-section" data-scroll-reveal>
      <div class="container">
        <div class="closing-shell">
          <p class="section-label">Closing</p>
          <blockquote class="closing-quote">
            <h2 class="section-heading section-heading--dark">
              You are not becoming someone new.
              <br />
              You are returning to who you have always been.
            </h2>
          </blockquote>
          <p class="body-copy body-copy--dark italic-note">
            When you are ready...
            <br />
            SEWL will be here.
          </p>
          <div class="hero-actions">
            <a class="primary-button" href={site.liveUrl}>Enter SEWL</a>
            <a class="ghost-button ghost-button--dark" href="/the-path">Begin Your Rhythm</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: min(1240px, calc(100vw - 40px));
    margin: 0 auto;
  }

  .hero-content {
    max-width: 900px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #c4956a;
  }

  .section-label::before {
    content: '';
    width: 48px;
    height: 1px;
    background: rgba(196, 149, 106, 0.72);
    flex: 0 0 48px;
  }

  .hero-title {
    max-width: 900px;
    color: #faf6f0;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.9rem, 10vw, 8.2rem);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .hero-word-shell {
    display: inline-block;
    overflow: hidden;
    margin-right: 0.25em;
  }

  .hero-word {
    display: inline-block;
  }

  .hero-lines {
    margin-top: 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-style: italic;
    color: rgba(250, 246, 240, 0.72);
    line-height: 2.2;
    letter-spacing: 0.06em;
  }

  .hero-lines span {
    display: block;
  }

  .hero-descriptor {
    margin-top: 18px;
    max-width: 580px;
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    line-height: 1.95;
    color: rgba(250, 246, 240, 0.7);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .primary-button,
  .ghost-button,
  .membership-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 14px 32px;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .primary-button {
    background: #c4956a;
    border: 1px solid #c4956a;
    color: #1a0a2e;
  }

  .ghost-button {
    background: transparent;
    border: 1px solid rgba(196, 149, 106, 0.5);
    color: #faf6f0;
  }

  .ghost-button--dark {
    color: #1a0a2e;
    border-color: rgba(196, 149, 106, 0.5);
  }

  .scroll-indicator {
    position: absolute;
    right: clamp(24px, 5vw, 48px);
    bottom: 34px;
    writing-mode: vertical-rl;
    text-transform: uppercase;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    color: rgba(250, 246, 240, 0.54);
  }

  .scroll-indicator::before {
    content: '';
    display: inline-block;
    width: 1px;
    height: 56px;
    margin-bottom: 12px;
    background: linear-gradient(180deg, rgba(196,149,106,0), rgba(196,149,106,0.82));
  }

  .light-section,
  .dark-section,
  .membership-section,
  .closing-section {
    padding: clamp(90px, 12vw, 132px) 0;
  }

  .light-section {
    color: #1a0a2e;
  }

  .dark-section {
    background: #1a0a2e;
    color: #faf6f0;
  }

  .two-column {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.86fr);
    gap: clamp(28px, 6vw, 90px);
    align-items: start;
  }

  .poetic-column {
    max-width: 760px;
  }

  .poetic-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 28px;
  }

  .belief-column {
    display: grid;
    gap: 18px;
    padding-top: 68px;
  }

  .belief-item {
    display: grid;
    grid-template-columns: 12px 1fr;
    gap: 16px;
    align-items: start;
  }

  .belief-dot {
    width: 7px;
    height: 7px;
    margin-top: 12px;
    border-radius: 999px;
    background: #c4956a;
    box-shadow: 0 0 0 7px rgba(196, 149, 106, 0.1);
  }

  .belief-item p,
  .body-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.95;
  }

  .body-copy {
    color: rgba(250, 246, 240, 0.78);
  }

  .body-copy--dark,
  .belief-item p {
    color: rgba(26, 10, 46, 0.8);
  }

  .italic-note {
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .section-header {
    max-width: 820px;
    margin-bottom: 34px;
  }

  .section-header--narrow {
    max-width: 760px;
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.9rem, 7vw, 5.4rem);
    line-height: 1.02;
    color: #faf6f0;
  }

  .section-heading--dark {
    color: #1a0a2e;
  }

  .pillars-row {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: none;
  }

  .pillars-row::-webkit-scrollbar {
    display: none;
  }

  .pillar-card {
    flex: 0 0 min(78vw, 400px);
    min-height: 480px;
    padding: 34px;
    border: 1px solid rgba(196, 149, 106, 0.2);
    border-radius: 20px;
    background: linear-gradient(160deg, rgba(26,10,46,0.97) 0%, rgba(36,16,58,0.95) 100%);
    transition: transform 0.35s ease, border-color 0.35s ease;
  }

  .pillar-card:hover {
    transform: translateY(-6px);
    border-color: rgba(196, 149, 106, 0.6);
  }

  .card-eyebrow {
    margin-bottom: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #c4956a;
  }

  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.6rem, 5vw, 3.8rem);
    line-height: 1.02;
    margin-bottom: 16px;
    color: #faf6f0;
  }

  .card-actions {
    margin-top: 28px;
  }

  .shift-shell {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .shift-copy {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .shift-pairs {
    display: grid;
    gap: 18px;
  }

  .shift-pair {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.02;
    color: #1a0a2e;
  }

  .shift-arrow {
    color: #c4956a;
  }

  .membership-section {
    background: linear-gradient(180deg, #1A0A2E 0%, #12071E 100%);
    color: #faf6f0;
  }

  .membership-shell {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .membership-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .membership-button {
    background: rgba(250, 246, 240, 0.04);
    border: 1px solid rgba(196, 149, 106, 0.24);
    color: #faf6f0;
  }

  .membership-copy {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .closing-section {
    padding: clamp(90px, 12vw, 132px) 0 clamp(60px, 8vw, 96px);
    background: radial-gradient(ellipse at 30% 50%, rgba(196,149,106,0.06) 0%, transparent 60%), #faf6f0;
    color: #1a0a2e;
  }

  .closing-shell {
    max-width: 860px;
  }

  .closing-quote h2 {
    font-style: italic;
  }

  @media (max-width: 900px) {
    .two-column {
      grid-template-columns: 1fr;
    }

    .belief-column {
      padding-top: 0;
    }

    .scroll-indicator {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero-actions,
    .membership-buttons {
      flex-direction: column;
    }

    .primary-button,
    .ghost-button,
    .membership-button {
      width: 100%;
    }
  }
</style>
