---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { tokens } from '../config/tokens';
import { site, thePathContent } from '../data/content';
---

<BaseLayout title="SEWL — The Path" description="Choose your path gently inside the SEWL rhythm.">
  <Navbar />

  <main>
    <section class="path-hero hero" style={`background: ${tokens.gradientHero};`}>
      <div class="container">
        <div class="hero-copy">
          <p class="section-label section-label--light">The Path</p>
          <h1 class="hero-title">Choose your path gently.</h1>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="light-section" data-scroll-reveal style={`background: ${tokens.gradientLight};`}>
      <div class="container section-stack">
        <div class="copy-shell">
          <p class="section-label">This Is Not a Program</p>
          <h2 class="section-title section-title--dark">This is a way of living.</h2>
        </div>
        <div class="copy-shell copy-shell--body">
          <p class="body-copy body-copy--dark">This is not something you rush through.</p>
          <p class="body-copy body-copy--dark">This is not something you consume and move on from.</p>
          <p class="body-copy body-copy--dark">{`Inside ${site.name}, you are guided back to what is natural:`}</p>
          <p class="body-copy body-copy--dark">— how you eat</p>
          <p class="body-copy body-copy--dark">— how you care for your body</p>
          <p class="body-copy body-copy--dark">— how you speak to yourself</p>
          <p class="body-copy body-copy--dark">— how you move through your days</p>
          <p class="body-copy body-copy--dark">Gently. Consistently. In truth.</p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="dark-section" data-scroll-reveal>
      <div class="container">
        <div class="copy-shell">
          <p class="section-label section-label--light">Who This Is For</p>
          <h2 class="section-title">This space is for the woman who feels:</h2>
        </div>

        <div class="quote-grid">
          {thePathContent.whoItIsFor.map((quote) => (
            <div class="quote-card" data-scroll-reveal>
              <p>{quote}</p>
            </div>
          ))}
        </div>

        <div class="copy-shell copy-shell--body" style="margin-top: 24px;">
          <p class="body-copy">You don't need to have it all together. You just need to be willing to begin.</p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="dark-section" data-scroll-reveal>
      <div class="container section-stack">
        <p class="section-label">Membership</p>

        <div class="membership-grid">
          <article class="card card--light" data-scroll-reveal>
            <div class="card-eyebrow">SEWL Entry (Free)</div>
            <h2 class="membership-title">SEWL Entry (Free)</h2>
            <p class="body-copy italic-note">Step inside and listen.</p>
            <p class="body-copy">This is your introduction to SEWL.</p>
            <div class="copy-shell copy-shell--body">
              <p class="body-copy">Weekly guidance</p>
              <p class="body-copy">Sovereign broadcasts</p>
              <p class="body-copy">Reflections</p>
            </div>
            <p class="body-copy italic-note">Enter freely. Move gently.</p>
            <p class="price-display price-display--small">Free</p>
            <div class="card-actions">
              <a class="primary-button" href={site.liveUrl}>Enter SEWL</a>
            </div>
          </article>

          <article class="card card--featured" data-scroll-reveal>
            <div class="card-eyebrow">Sewl Rhythm</div>
            <h2 class="membership-title">Sewl Rhythm</h2>
            <p class="body-copy italic-note">Build your foundation.</p>
            <p class="body-copy">
              This is where your practice begins. You are no longer just observing... you are learning how to live this.
            </p>
            <div class="copy-shell copy-shell--body">
              <p class="body-copy">Access to all 3 pillars: Nourish, Temple, Voice</p>
              <p class="body-copy">Weekly rhythms to follow</p>
              <p class="body-copy">Audio guidance (meditations, affirmations)</p>
              <p class="body-copy">{`Full access to the ${site.circleLabel} community`}</p>
            </div>
            <p class="body-copy italic-note">This is not about doing everything. It's about returning... consistently.</p>
            <p class="price-display">{`${site.rhythmPrice}/month`}</p>
            <div class="card-actions">
              <a class="primary-button" href={site.pathUrl}>Begin Your Rhythm</a>
            </div>
          </article>

          <article class="card card--light" data-scroll-reveal>
            <div class="card-eyebrow">{site.circleLabel}</div>
            <h2 class="membership-title">{site.circleLabel}</h2>
            <p class="body-copy italic-note">Step into embodiment.</p>
            <p class="body-copy">
              This is for the woman ready to go deeper. Here, you are not just practicing... you are becoming.
            </p>
            <div class="copy-shell copy-shell--body">
              <p class="body-copy">Everything in Rhythm, plus:</p>
              <p class="body-copy">{`Monthly live ${site.circleLabel} gatherings`}</p>
              <p class="body-copy">Deeper teachings and guided rituals</p>
              <p class="body-copy">Seasonal resets (womb, body, mind)</p>
              <p class="body-copy">Closer connection and guidance</p>
            </div>
            <p class="body-copy italic-note">This space is more intimate. More present. More transformative.</p>
            <p class="price-display">{`${site.circlePrice}/month`}</p>
            <div class="card-actions">
              <a class="primary-button" href={site.pathUrl}>{`Enter the ${site.circleLabel}`}</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="dark-section" data-scroll-reveal>
      <div class="container">
        <div class="copy-shell copy-shell--body">
          <p class="section-label section-label--light">Gentle Reminder</p>
          <p class="body-copy">You do not need to rush.</p>
          <p class="body-copy">You do not need to choose perfectly.</p>
          <p class="body-copy">You simply choose where you are... and begin from there.</p>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="dark-section dark-section--tight" data-scroll-reveal>
      <div class="container">
        <div class="copy-shell">
          <p class="section-label section-label--light">Closing</p>
          <blockquote>
            <h2 class="section-title section-title--italic">
              You are not becoming someone new...
              <br />
              you are returning to who you have always been.
            </h2>
          </blockquote>
          <p class="body-copy italic-note">{`When you are ready, ${site.name} will be here.`}</p>
          <div class="hero-actions">
            <a class="primary-button" href={site.liveUrl}>Enter SEWL</a>
            <a class="ghost-button" href={site.pathUrl}>Begin Your Rhythm</a>
            <a class="ghost-button" href={site.pathUrl}>{`Enter the ${site.circleLabel}`}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: min(1240px, calc(100vw - 40px));
    margin: 0 auto;
  }

  .path-hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: clamp(140px, 18vw, 200px) 0 clamp(80px, 10vw, 120px);
  }

  .hero-copy,
  .copy-shell {
    max-width: 760px;
  }

  .copy-shell--body,
  .section-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .section-stack {
    gap: 28px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #c4956a;
  }

  .section-label::before {
    content: '';
    width: 48px;
    height: 1px;
    background: rgba(196,149,106,0.72);
    flex: 0 0 48px;
  }

  .hero-title {
    font-size: clamp(4rem, 11vw, 9rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: #faf6f0;
  }

  .section-title {
    font-size: clamp(2.6rem, 6.5vw, 4.8rem);
    line-height: 1.02;
    color: #faf6f0;
  }

  .section-title--dark {
    color: #1a0a2e;
  }

  .section-title--italic {
    font-style: italic;
  }

  .body-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.95;
    color: rgba(250,246,240,0.8);
  }

  .body-copy--dark {
    color: rgba(26,10,46,0.8);
  }

  .italic-note {
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .light-section,
  .dark-section {
    padding: clamp(90px, 12vw, 132px) 0;
  }

  .dark-section {
    background: #1a0a2e;
  }

  .dark-section--tight {
    padding-bottom: clamp(60px, 8vw, 96px);
  }

  .quote-grid {
    display: grid;
    gap: 16px;
    margin-top: 26px;
  }

  .quote-card {
    padding: 22px 24px;
    border-radius: 12px;
    border: 1px solid rgba(196,149,106,0.22);
    background: rgba(250,246,240,0.05);
  }

  .quote-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.9;
    color: rgba(250,246,240,0.84);
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .membership-grid {
    display: grid;
    gap: 24px;
  }

  .card {
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(32px, 5vw, 56px);
    border: 1px solid rgba(196,149,106,0.22);
    border-radius: 20px;
    background: rgba(250,246,240,0.03);
    width: 100%;
  }

  .card--featured {
    border-color: rgba(196,149,106,0.5);
    background: rgba(196,149,106,0.06);
  }

  .card-eyebrow {
    margin-bottom: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #c4956a;
  }

  .membership-title {
    font-size: clamp(2.2rem, 4.8vw, 3.6rem);
    line-height: 1.02;
    color: #faf6f0;
    margin-bottom: 14px;
  }

  .price-display {
    margin-top: 12px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    color: #c4956a;
    line-height: 1;
  }

  .price-display--small {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .card-actions,
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 24px;
  }

  .primary-button,
  .ghost-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 14px 32px;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .primary-button {
    background: #c4956a;
    border: 1px solid #c4956a;
    color: #1a0a2e;
  }

  .ghost-button {
    background: transparent;
    border: 1px solid rgba(196,149,106,0.5);
    color: #faf6f0;
  }

  @media (max-width: 640px) {
    .primary-button,
    .ghost-button {
      width: 100%;
    }
  }
</style>
